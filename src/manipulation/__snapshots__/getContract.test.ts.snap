exports[`getContract given: a DomainEntity with primary, unique, alias, and nested when: the contract is embedded as a field in a parent z.object then: the pragma survives on the nested field of the parent json-schema 1`] = `
{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "surfboard": {
      "additionalProperties": false,
      "properties": {
        "rider": {
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string",
            },
            "uuid": {
              "type": "string",
            },
          },
          "required": [
            "name",
          ],
          "type": "object",
        },
        "serialNumber": {
          "type": "string",
        },
        "uuid": {
          "type": "string",
        },
      },
      "required": [
        "serialNumber",
        "rider",
      ],
      "type": "object",
      "x-domain-object": {
        "alias": {
          "plural": "surfboards",
          "singular": "surfboard",
        },
        "name": "SeaturtleSurfboard",
        "nested": {
          "rider": "Seaturtle",
        },
        "primary": [
          "uuid",
        ],
        "unique": [
          "serialNumber",
        ],
      },
    },
  },
  "required": [
    "surfboard",
  ],
  "type": "object",
}
`;

